# Game binary (copyrighted, ~96 MB) — obtain separately, see docs/ASSETS.md
*.apk
*.aab
*.dex
# EXCEPTION : APK committé volontairement (évite re-téléchargement après reset conteneur)
!/game/disney-heroes-12.1.0.apk
# Decompiled bytecode (regenerable via tools/decompile.sh)
libs/*.jar
classes*.jar
# EXCEPTION : jar décompilé + dépendance committés (évite re-décompilation, lente, après reset)
!/libs/game.jar
!/libs/commons-logging.jar
/decompiled/
/build/
/run/
# Downloaded live assets (large; from archive.org — see docs/ASSETS.md)
/assets-cache/
*.zip
# Scratch / OS
*.log
.DS_Store
__pycache__/
*.pyc
/tmp/

# Compiled Java / dex2jar error dumps
*.class
*-error.zip
/server/smoke/out/
/desktop-port/build/
*.ppm
/desktop-port/.gradle/
.gradle/
/libs/game-logic.jar
